# Copy this file to backend/.env and replace the placeholder values.

APP_ENV=development
APP_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Use DATABASE_URL first. The DB_* values are only used when DATABASE_URL is empty.
DATABASE_URL=mysql+pymysql://root:your_password@127.0.0.1:3306/dataplatform
DB_DRIVER=mysql+pymysql
DB_USER=root
DB_PASSWORD=your_password
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=dataplatform

SQLALCHEMY_ECHO=false
CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
ALLOWED_HOSTS=127.0.0.1,localhost

# AI assistant configuration
AI_PROVIDER=alibaba
AI_MODEL=qwen-plus
# For Alibaba DashScope, prefer DASHSCOPE_API_KEY. AI_API_KEY is kept as a generic fallback.
DASHSCOPE_API_KEY=replace-with-your-dashscope-api-key
AI_API_KEY=sk-9dc28efed19a421591e741a11735b29f
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_TIMEOUT_SECONDS=45
